    "db:seed": "node node_modules/knex/bin/cli.js --knexfile dist/config/knexfile.js seed:run",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bull": "^4.12.2",
    "bullmq": "^5.76.5",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "pino": "^9.3.1",
